# Шаблон конфига моста к Битрикс24. СЕКРЕТОВ ЗДЕСЬ НЕТ.
#
# Как использовать:
#   cp .b24-bridge/webhook.env.example .b24-bridge/webhook.env
#   chmod 600 .b24-bridge/webhook.env
#   затем впиши свой URL вебхука в webhook.env (НЕ в этот .example-файл).
#
# Рабочий файл webhook.env в .gitignore — он не попадёт в репозиторий.
# Как выпустить вебхук — см. skills/b24-bridge/SKILL.md, раздел «Настройка».

# Полный URL входящего вебхука, целиком, со слешем на конце.
# <ваш-портал> — хост как есть: облачный (компания.bitrix24.ru и т.п.)
# или коробочный / self-hosted на своём домене либо IP.
B24_WEBHOOK=https://<ваш-портал>/rest/<число>/<токен>/

# (опционально) ID владельца хука — для команд «мои задачи / мой календарь».
# Если не указать, агент определит его через user.current при первом вызове.
B24_USER_ID=<ваш-id>
